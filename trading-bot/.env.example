# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=tradingbot
DB_PASSWORD=changeme
DB_NAME=tradingbot

# ── Application ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
ENCRYPTION_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
DEBUG=false

# ── Zerodha Kite Connect ──────────────────────────────────────────────────────
# Get from: https://developers.kite.trade/
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# ── Delta Exchange ────────────────────────────────────────────────────────────
# Get from: https://www.delta.exchange/app/account/api-keys
DELTA_API_KEY=your_delta_api_key
DELTA_API_SECRET=your_delta_api_secret
DELTA_BASE_URL=https://api.delta.exchange

# ── Telegram Notifications ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── First Run Admin ───────────────────────────────────────────────────────────
FIRST_RUN_ADMIN_USERNAME=admin
FIRST_RUN_ADMIN_PASSWORD=changeme_strong_password
